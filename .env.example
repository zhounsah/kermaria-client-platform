# EXEMPLE UNIQUEMENT : ne jamais placer de vrai secret dans ce fichier.
# Les placeholders doivent être remplacés par des variables d'environnement
# injectées localement. Ils ne sont pas utilisables en production.

NODE_ENV=development
ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development
# Staging attendue : NODE_ENV=production, ASPNETCORE_ENVIRONMENT=Staging,
# DOTNET_ENVIRONMENT=Staging.
# Preproduction attendue : NODE_ENV=production, ASPNETCORE_ENVIRONMENT=Production,
# DOTNET_ENVIRONMENT=Production.
PUBLIC_PORTAL_URL=https://portal.example.invalid

# Variable strictement serveur : ne jamais utiliser PUBLIC_ ou NEXT_PUBLIC_.
INTERNAL_API_URL=http://localhost:5000
# false en local. En production, localhost est refusé sauf dérogation explicite.
ALLOW_LOCAL_INTERNAL_API_URL=false
SERVICE_AUTH_TOKEN=**REPLACE_WITH_SECURE_VALUE**

SQL_PROVIDER=mariadb
SQL_HOST=KERMARIA-SRV-07.home.bzh
SQL_PORT=3306
SQL_DATABASE=TEST_WEB
SQL_USERNAME=TEST_WEB
SQL_PASSWORD=**REPLACE_WITH_SECURE_VALUE**

AD_INTEGRATION_MODE=disabled
# Valeurs autorisees : disabled | mock | read_only | controlled_write
AD_DOMAIN=home.bzh
AD_CLIENTS_OU_DN=OU=TEST_SITE_WEB,DC=home,DC=bzh
AD_SERVICE_ACCOUNT_USERNAME=HOME\svc_api_portal_ad
AD_SERVICE_ACCOUNT_PASSWORD=**REPLACE_WITH_SECURE_VALUE**
AD_CONNECT_TIMEOUT_MS=3000
AD_QUERY_TIMEOUT_MS=5000
AD_MAX_RESULTS=25

# Integration BPCE (facturation reelle) - V0.20+.
# Valeurs autorisees : disabled | mock | live.
# Le mode live emet de vraies factures cote banque : ne jamais l'activer en
# phase de tests sans validation explicite.
BPCE_INTEGRATION_MODE=disabled
BPCE_BASE_URL=https://www.gestion-factures.banquepopulaire.fr
# Secret strictement serveur. Ne jamais commiter ni journaliser.
BPCE_REFRESH_TOKEN=**REPLACE_WITH_SECURE_VALUE**
# Identifiant du profil de facturation cote BPCE. Renseigne via le dashboard
# ou via la commande bpce:sync-sender (slice B).
BPCE_SENDER_ID=
BPCE_REQUEST_TIMEOUT_MS=10000

LOG_LEVEL=Information

# Session portail. Le token brut reste uniquement dans le cookie HttpOnly.
SESSION_COOKIE_NAME=kermaria_portal_session
# false uniquement en développement local ; utiliser true en production.
SESSION_COOKIE_SECURE=false
# Valeurs autorisées : lax, strict, none. `none` exige Secure=true.
# Recommandation : `strict` en staging/préproduction si les parcours restent same-site.
SESSION_COOKIE_SAME_SITE=lax
SESSION_DURATION_MINUTES=60
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=10

# Seed local Development uniquement. Ne jamais utiliser un vrai compte client.
# En preproduction, les variables DEMO_* doivent rester absentes.
DEMO_PORTAL_EMAIL=demo.user@example.invalid
DEMO_PORTAL_PASSWORD=**REPLACE_WITH_SECURE_VALUE**
DEMO_INTERNAL_ADMIN_EMAIL=demo.admin@example.invalid
DEMO_INTERNAL_ADMIN_PASSWORD=**REPLACE_WITH_SECURE_VALUE**

# Variables optionnelles pour `npm run check:health` uniquement.
# Staging : définir les deux URLs de staging ; préproduction finale : adapter aux URLs cibles.
# API_INTERNAL_BASE_URL=https://api-internal-preprod.example.invalid
# WEBPORTAL_BASE_URL=https://portal-preprod.example.invalid
