# EXEMPLE UNIQUEMENT : ne jamais placer de vrai secret dans ce fichier.
# Les placeholders doivent être remplacés par des variables d'environnement
# injectées localement. Ils ne sont pas utilisables en production.

NODE_ENV=development
ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development
# Staging attendue : NODE_ENV=production, ASPNETCORE_ENVIRONMENT=Staging,
# DOTNET_ENVIRONMENT=Staging.
# Preproduction attendue : NODE_ENV=production, ASPNETCORE_ENVIRONMENT=Production,
# DOTNET_ENVIRONMENT=Production.
PUBLIC_PORTAL_URL=https://portal.example.invalid

# Variable strictement serveur : ne jamais utiliser PUBLIC_ ou NEXT_PUBLIC_.
INTERNAL_API_URL=http://localhost:5000
# false en local. En production, localhost est refusé sauf dérogation explicite.
ALLOW_LOCAL_INTERNAL_API_URL=false
SERVICE_AUTH_TOKEN=**REPLACE_WITH_SECURE_VALUE**

# V0.37 centre de telechargements : repertoire prive utilise uniquement par
# API-INTERNAL pour les binaires internes. Obligatoire hors Development et
# doit rester hors de tout web root/public.
DOWNLOAD_STORAGE_ROOT=

SQL_PROVIDER=mariadb
SQL_HOST=KERMARIA-SRV-07.home.bzh
SQL_PORT=3306
SQL_DATABASE=TEST_WEB
SQL_USERNAME=TEST_WEB
SQL_PASSWORD=**REPLACE_WITH_SECURE_VALUE**

AD_INTEGRATION_MODE=disabled
# Valeurs autorisees : disabled | mock | read_only | controlled_write
AD_DOMAIN=home.bzh
AD_CLIENTS_OU_DN=OU=TEST_SITE_WEB,DC=home,DC=bzh
# Racine parent obligatoire pour les DN manipules par l'API. Utiliser
# l'ancetre commun le plus serre possible, puis whitelist stricte avec
# AD_ALLOWED_ROOTS pour limiter l'ecriture aux OUs clients et groupes voulus.
AD_REQUIRED_OU_ROOT=DC=home,DC=bzh
# Liste blanche DN des racines AD autorisees pour le provisioning
# (separer par point-virgule).
AD_ALLOWED_ROOTS=OU=TEST_SITE_WEB,DC=home,DC=bzh;OU=GLOBAL_GROUPS,DC=home,DC=bzh
AD_SERVICE_ACCOUNT_USERNAME=HOME\svc_api_portal_ad
AD_SERVICE_ACCOUNT_PASSWORD=**REPLACE_WITH_SECURE_VALUE**
AD_CONNECT_TIMEOUT_MS=3000
AD_QUERY_TIMEOUT_MS=5000
AD_MAX_RESULTS=25
SUBSCRIPTION_PROVISIONING_GROUPS__ACCES-RDS=GG_RDS
SUBSCRIPTION_PROVISIONING_GROUPS__ACCES-VPN=GG_VPN
SUBSCRIPTION_PROVISIONING_GROUPS__RADIO=GG_Radio
SUBSCRIPTION_PROVISIONING_SERVICE_GROUPS__ACCES-RDS=GG_RDS
SUBSCRIPTION_PROVISIONING_SERVICE_GROUPS__ACCES-VPN=GG_VPN
# Exemple futur :
# SUBSCRIPTION_PROVISIONING_SERVICE_GROUPS__NEXTCLOUD=GG_NextCloud
# SUBSCRIPTION_PROVISIONING_SERVICE_LABELS__NEXTCLOUD=Nextcloud
# Les packs grand public v0.32 ont des mappings par defaut integres au code :
# PACK-ACCES-* => GG_VPN ; PACK-BUREAU-* => GG_RDS,GG_VPN ; PACK-PRO-* => GG_VPN.
# Ajouter une variable ci-dessous uniquement pour surcharger ces valeurs.
# SUBSCRIPTION_PROVISIONING_GROUPS__PACK-BUREAU-1M-MENS=GG_RDS,GG_VPN
# SUBSCRIPTION_PROVISIONING_GROUPS__PACK-ACCES-6M-COMPT=GG_VPN
AD_PROVISIONING_GROUP_DNS__GG_RDS=
AD_PROVISIONING_GROUP_DNS__GG_VPN=
AD_PROVISIONING_GROUP_DNS__GG_Radio=
# AD_PROVISIONING_GROUP_DNS__GG_NextCloud=
SUBSCRIPTION_PROVISIONING_MAX_ATTEMPTS=3
SUBSCRIPTION_PROVISIONING_RETRY_DELAY_MS=200

# Integration BPCE (facturation reelle) - V0.20+.
# Valeurs autorisees : disabled | mock | live.
# Le mode live emet de vraies factures cote banque : ne jamais l'activer en
# phase de tests sans validation explicite.
BPCE_INTEGRATION_MODE=disabled
BPCE_BASE_URL=https://www.gestion-factures.banquepopulaire.fr
# Secret strictement serveur. Ne jamais commiter ni journaliser.
BPCE_REFRESH_TOKEN=**REPLACE_WITH_SECURE_VALUE**
# Identifiant du profil de facturation cote BPCE. Renseigne via le dashboard
# ou via la commande bpce:sync-sender (slice B).
BPCE_SENDER_ID=
BPCE_REQUEST_TIMEOUT_MS=10000

# Canal e-mail transactionnel V0.21. Default disabled : aucun envoi reel tant
# que l'infra cible (R740xd) n'est pas livree.
# Valeurs autorisees : disabled | mock | live.
# mock = journalise sans envoyer ; live = envoi reel via SMTP.
EMAIL_INTEGRATION_MODE=disabled
# OVH MX Plan : SMTP_HOST=ssl0.ovh.net, SMTP_PORT=587, STARTTLS,
# SMTP_USERNAME = adresse complete (ex : support@zacharyhounsa.ovh).
# System.Net.Mail.SmtpClient ne supporte que STARTTLS, pas SMTPS direct :
# port 587 obligatoire.
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_STARTTLS=true
SMTP_USERNAME=
SMTP_PASSWORD=**REPLACE_WITH_SECURE_VALUE**
SMTP_FROM_ADDRESS=
SMTP_FROM_DISPLAY_NAME=Kermaria
SMTP_TIMEOUT_MS=10000

# V0.30 partiel : allowlist des destinataires acceptes en mode `live`.
# Fail-closed : par defaut, tout envoi live est bloque tant qu'aucune
# entree n'est autorisee. Ne desactiver EMAIL_LIVE_ALLOWLIST_ONLY qu'a la
# V1.0 RC apres validation juridique et supervision. Chaque entree peut
# etre une adresse complete (`zhounsah@home.bzh`) ou un motif de domaine
# (`@home.bzh`). Separateurs autorises : virgule, point-virgule, saut de
# ligne.
EMAIL_LIVE_ALLOWLIST_ONLY=true
EMAIL_LIVE_ALLOWLIST=

LOG_LEVEL=Information

# Journalisation fichier (optionnel). Si LOG_FILE_DIRECTORY est defini,
# un fichier api-internal-YYYY-MM-DD.log est cree dans ce repertoire a chaque
# demarrage. Les fichiers plus anciens que LOG_FILE_RETENTION_DAYS sont
# supprimes automatiquement au demarrage suivant.
# Laisser vide pour desactiver la journalisation fichier.
# LOG_FILE_DIRECTORY=logs
# LOG_FILE_LEVEL=Information
# LOG_FILE_RETENTION_DAYS=30

# Coordonnees de reglement affichees sur les factures emises cote portail client.
# BILLING_IBAN et BILLING_BIC sont affiches pour le virement bancaire.
# BILLING_PAYPAL_URL est le lien PayPal.me (ex: https://www.paypal.me/tonpseudo).
# Laisser vide pour ne pas afficher la methode correspondante.
# Paiement PayPal en ligne (optionnel). Cree une app sur developer.paypal.com
# et utilise les credentials sandbox pour les tests, live pour la production.
# PAYPAL_MODE : sandbox (defaut) | live
PAYPAL_CLIENT_ID=**REPLACE_WITH_PAYPAL_CLIENT_ID**
PAYPAL_CLIENT_SECRET=**REPLACE_WITH_PAYPAL_CLIENT_SECRET**
PAYPAL_MODE=sandbox
# Webhook PayPal (V0.22+) : ID du webhook configure dans le dashboard developer
# et flag pour activer la verification de signature. Laisser PAYPAL_WEBHOOK_VERIFY=true
# en production. Mettre a false uniquement pour debug local en sandbox.
PAYPAL_WEBHOOK_ID=**REPLACE_WITH_PAYPAL_WEBHOOK_ID**
PAYPAL_WEBHOOK_VERIFY=true

# Paiement Stripe en ligne (optionnel, V0.29), rail parallele a PayPal.
# Cree un compte sur dashboard.stripe.com et utilise les cles test pour les
# tests, live uniquement a partir de V1.0 beta 1 (garde-fou identique a
# PayPal et BPCE).
# STRIPE_MODE : disabled (defaut) | test | live
STRIPE_SECRET_KEY=**REPLACE_WITH_STRIPE_SECRET_KEY**
STRIPE_PUBLISHABLE_KEY=**REPLACE_WITH_STRIPE_PUBLISHABLE_KEY**
STRIPE_MODE=disabled
# Webhook Stripe (V0.29) : secret de signature configure dans le dashboard
# developer et flag pour activer la verification locale (HMAC calcule sans
# appel reseau, contrairement a PayPal). Laisser STRIPE_WEBHOOK_VERIFY=true
# en production. Mettre a false uniquement pour debug local.
STRIPE_WEBHOOK_SECRET=**REPLACE_WITH_STRIPE_WEBHOOK_SECRET**
STRIPE_WEBHOOK_VERIFY=true

BILLING_IBAN=**REPLACE_WITH_IBAN**
BILLING_BIC=**REPLACE_WITH_BIC**
BILLING_PAYPAL_URL=
BILLING_TRANSFER_LABEL=Zachary HOUNSA-HOUNKPA EI

# Inscription self-service (V0.26). Kill switch global : laisser false tant
# que la validation juridique/process n'est pas faite. Aucune creation AD
# automatique a l'approbation ; seul un portal_user est cree.
SIGNUP_ENABLED=false
SIGNUP_RATE_LIMIT_PER_IP_PER_HOUR=3
SIGNUP_RATE_LIMIT_PER_EMAIL_PER_24H=1
SIGNUP_VERIFICATION_TOKEN_TTL_HOURS=24
SIGNUP_PASSWORD_SETUP_TOKEN_TTL_HOURS=24
# Reserve : doit rester false jusqu'a la V1.0 RC (validation manuelle
# obligatoire). Aucun code ne bascule sur cette valeur dans ce lot.
SIGNUP_AUTO_APPROVE=false
# hCaptcha (obligatoire des que SIGNUP_ENABLED=true). La cle site est
# publique (injectee dans le HTML) ; la cle secrete reste server-only et
# n'est jamais exposee au navigateur. En Development sans cle, la
# verification est sautee pour rester testable ; en production, l'absence
# de HCAPTCHA_SECRET_KEY fait echouer chaque soumission (fail-closed).
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=**REPLACE_WITH_HCAPTCHA_SECRET_KEY**

# Session portail. Le token brut reste uniquement dans le cookie HttpOnly.
SESSION_COOKIE_NAME=kermaria_portal_session
# false uniquement en développement local ; utiliser true en production.
SESSION_COOKIE_SECURE=false
# Valeurs autorisées : lax, strict, none. `none` exige Secure=true.
# Recommandation : `strict` en staging/préproduction si les parcours restent same-site.
SESSION_COOKIE_SAME_SITE=lax
SESSION_DURATION_MINUTES=60
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=10

# Seed local Development uniquement. Ne jamais utiliser un vrai compte client.
# En preproduction, les variables DEMO_* doivent rester absentes.
DEMO_PORTAL_EMAIL=demo.user@example.invalid
DEMO_PORTAL_PASSWORD=**REPLACE_WITH_SECURE_VALUE**
DEMO_INTERNAL_ADMIN_EMAIL=demo.admin@example.invalid
DEMO_INTERNAL_ADMIN_PASSWORD=**REPLACE_WITH_SECURE_VALUE**

# Variables optionnelles pour `npm run check:health` uniquement.
# Staging : définir les deux URLs de staging ; préproduction finale : adapter aux URLs cibles.
# API_INTERNAL_BASE_URL=https://api-internal-preprod.example.invalid
# WEBPORTAL_BASE_URL=https://portal-preprod.example.invalid
